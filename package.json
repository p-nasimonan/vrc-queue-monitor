{
  "name": "vrc-queue-monitor",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.0+sha512.2b5753de015d480eeb88f5b5b61e0051f05b4301808a82ec8b840c9d2adf7748eb352c83f5c1593ca703ff1017295bc3fdd3119abb9686efc96b9fcb18200937",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:mock": "NEXT_PUBLIC_USE_MOCK_API=true pnpm --filter vrc-queue-monitor-frontend dev",
    "build": "pnpm --filter vrc-queue-monitor-frontend build",
    "start": "pnpm --filter vrc-queue-monitor-frontend start",
    "lint": "pnpm --filter vrc-queue-monitor-frontend lint",
    "db:up": "docker compose up postgres -d",
    "db:down": "docker compose down postgres",
    "api:up": "docker compose up api -d",
    "api:down": "docker compose down api",
    "api:dev": "cd apps/backend && python src/api.py",
    "collector:up": "docker compose up collector -d",
    "collector:down": "docker compose down collector",
    "all:up": "docker compose up -d"
  }
}