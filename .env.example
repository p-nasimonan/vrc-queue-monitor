# VRChat認証情報
# VRC_USERNAME: VRChatアカウントのメールアドレス（表示名ではない）
VRC_USERNAME=your_email@example.com
VRC_PASSWORD=your_vrchat_password
# TOTP_SECRET: 2FAは有効にしてください。スペースなしのBase32形式（例: JBSWY3DPEHPK3PXP）
TOTP_SECRET=

# 監視対象のVRChatグループID
VRC_GROUP_ID=grp_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 収集間隔（分）
# POLL_INTERVAL_MINUTES: メトリクス収集間隔（高頻度）
POLL_INTERVAL_MINUTES=2
# DISCOVERY_INTERVAL_MINUTES: インスタンス発見間隔（低頻度）
DISCOVERY_INTERVAL_MINUTES=10

TZ=

# ログレベル: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# ========== スケジュール設定 ==========
# SCHEDULE_TYPE: 監視タイプ
#   - always: 常時監視（デフォルト）
#   - weekday: 曜日指定
#   - day_of_month: 日付指定（5のつく日など）
SCHEDULE_TYPE=always

# SCHEDULE_DAYS: 監視する曜日または日付（カンマ区切り）
#   曜日の場合: mon,tue,wed,thu,fri,sat,sun または 0,1,2,3,4,5,6 (0=月曜)
#   日付の場合: 5,15,25 (5のつく日)
# 例: 毎週土日 → SCHEDULE_DAYS=sat,sun
# 例: 5のつく日 → SCHEDULE_DAYS=5,15,25
SCHEDULE_DAYS=

# SCHEDULE_START_TIME: 監視開始時刻（日本時間、HH:MM形式）
# SCHEDULE_DURATION_MINUTES: 監視継続時間（分）
# 例: 22:00 から 150分（2時間30分）監視 → START=22:00, DURATION=150
# ※ 日をまたいでも日付は開始日で判定されるため、日またぎの設定も直感的に行えます
SCHEDULE_START_TIME=22:00
SCHEDULE_DURATION_MINUTES=180

# ========== PostgreSQL設定 ==========
DB_NAME=vrc_monitor
DB_USER=postgres
DB_PASSWORD=postgres

# ========== フロントエンド設定 ==========
# サイト名
NEXT_PUBLIC_SITE_NAME=VRC Queue Monitor

# 自動更新間隔（ミリ秒）: 60000 = 1分
NEXT_PUBLIC_REFRESH_INTERVAL=60000

# 表示するイベント日数
NEXT_PUBLIC_DISPLAY_DAYS=30

# デフォルトテーマ: light または dark
NEXT_PUBLIC_DEFAULT_THEME=light

# タイムゾーン（チャート・時刻表示に使用）: Asia/Tokyo, UTC など
NEXT_PUBLIC_TIMEZONE=Asia/Tokyo
